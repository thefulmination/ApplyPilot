# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Provider
GEMINI_API_KEY=           # Gemini Flash for scoring and first-pass generation
# DEEPSEEK_API_KEY=       # DeepSeek fallback for higher-quality retries
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=         # OpenAI fallback if preferred
# LLM_URL=http://127.0.0.1:8080/v1  # Local LLM (llama.cpp, Ollama)
# LLM_MODEL=gemini-2.5-flash
# LLM_SCORE_MODEL=gemini-2.5-flash
# APPLYPILOT_PREFERENCE_PROFILE_PATH=~/.applypilot/job_preference_profile.json
# LLM_JUDGE_MODEL=gemini-2.5-flash
# LLM_DIAGNOSE_MODEL=gemini-2.5-flash
# LLM_TAILOR_MODEL=gemini-2.5-flash
# LLM_COVER_MODEL=gemini-2.5-flash
# LLM_TAILOR_FALLBACK_MODEL=deepseek-v4-pro
# LLM_COVER_FALLBACK_MODEL=deepseek-v4-pro
# TAILOR_PRIMARY_ATTEMPTS=2
# TAILOR_HIGH_SCORE_PRIMARY_ATTEMPTS=1
# TAILOR_PREMIUM_MIN_SCORE=9.5
# DEEPSEEK_THINKING=disabled

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
