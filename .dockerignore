# Keep the image lean and PII/secret-free. profile.json + resume.pdf come from the Railway
# volume at /data/applypilot, never from the build context.
.git
.gitignore
.applypilot
.conda-env
.venv
.codex
.claude
**/__pycache__
*.pyc
*.db
*.db-wal
*.db-shm
*.sqlite
node_modules
.pytest_cache
tests
docs
chrome-workers
apply-workers
*.log
.env
.env.*
